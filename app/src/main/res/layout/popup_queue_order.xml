<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/queue_order_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurfaceContainerHigh"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_medium"
    android:paddingVertical="@dimen/spacing_small">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/spacing_small"
        android:text="@string/lbl_queue_order_title"
        android:textAppearance="@style/TextAppearance.Auxio.LabelLarge"
        android:textColor="?attr/colorPrimary" />

    <!-- Similarity -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_queue_order_similarity"
            android:textAppearance="@style/TextAppearance.Auxio.BodyMedium" />
        <TextView
            android:id="@+id/queue_order_similarity_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="+1.00" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:background="?attr/colorOutline" />
        <com.google.android.material.slider.Slider
            android:id="@+id/queue_order_similarity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.05"
            android:valueFrom="-1.0"
            android:valueTo="1.0" />
    </FrameLayout>

    <!-- Frequency -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_queue_order_frequency"
            android:textAppearance="@style/TextAppearance.Auxio.BodyMedium" />
        <TextView
            android:id="@+id/queue_order_frequency_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="0.00" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:background="?attr/colorOutline" />
        <com.google.android.material.slider.Slider
            android:id="@+id/queue_order_frequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.05"
            android:valueFrom="-1.0"
            android:valueTo="1.0" />
    </FrameLayout>

    <!-- Random -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_queue_order_random"
            android:textAppearance="@style/TextAppearance.Auxio.BodyMedium" />
        <TextView
            android:id="@+id/queue_order_random_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="0.00" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:background="?attr/colorOutline" />
        <com.google.android.material.slider.Slider
            android:id="@+id/queue_order_random"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.05"
            android:valueFrom="-1.0"
            android:valueTo="1.0"
            tools:ignore="SpeakableTextPresentCheck" />
    </FrameLayout>

    <!-- Actions -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="@dimen/spacing_small"
        android:background="?attr/colorOutlineVariant" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/spacing_small"
        android:text="@string/lbl_queue_order_mix_title"
        android:textAppearance="@style/TextAppearance.Auxio.LabelLarge"
        android:textColor="?attr/colorPrimary" />

    <!-- Metadata -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_queue_order_metadata"
            android:textAppearance="@style/TextAppearance.Auxio.BodyMedium" />
        <TextView
            android:id="@+id/queue_order_metadata_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="0.33" />
    </LinearLayout>
    <com.google.android.material.slider.Slider
        android:id="@+id/queue_order_metadata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="0.05"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        tools:ignore="SpeakableTextPresentCheck" />

    <!-- Axis -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_queue_order_axis"
            android:textAppearance="@style/TextAppearance.Auxio.BodyMedium" />
        <TextView
            android:id="@+id/queue_order_axis_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="0.34" />
    </LinearLayout>
    <com.google.android.material.slider.Slider
        android:id="@+id/queue_order_axis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="0.05"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        tools:ignore="SpeakableTextPresentCheck" />

    <!-- Acoustic -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_queue_order_acoustic"
            android:textAppearance="@style/TextAppearance.Auxio.BodyMedium" />
        <TextView
            android:id="@+id/queue_order_acoustic_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="0.33" />
    </LinearLayout>
    <com.google.android.material.slider.Slider
        android:id="@+id/queue_order_acoustic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="0.05"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        tools:ignore="SpeakableTextPresentCheck" />

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingTop="@dimen/spacing_small">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/queue_order_reset"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_queue_order_reset" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/queue_order_apply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_queue_order_apply" />
    </LinearLayout>

</LinearLayout>
