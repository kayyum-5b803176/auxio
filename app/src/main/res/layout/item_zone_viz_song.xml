<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/zone_viz_song_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_medium"
    android:paddingVertical="@dimen/spacing_small">

    <View
        android:id="@+id/zone_viz_song_swatch"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginEnd="@dimen/spacing_medium" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/zone_viz_song_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Auxio.BodyLarge"
            tools:text="Blinding Lights" />

        <TextView
            android:id="@+id/zone_viz_song_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="The Weeknd · Hindi / Energetic" />

    </LinearLayout>

    <TextView
        android:id="@+id/zone_viz_song_playing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_small"
        android:text="@string/lbl_zone_viz_now_playing"
        android:textAppearance="@style/TextAppearance.Auxio.LabelMedium"
        android:textColor="?attr/colorPrimary"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>
